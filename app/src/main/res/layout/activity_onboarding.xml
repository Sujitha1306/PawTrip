<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:id="@+id/tvWelcomeMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome!\nTell us about your pet 🐾"
            android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/dark_green"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Name *" android:textColor="@color/dark_green"
            android:textStyle="bold" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etPetName"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="e.g. Bruno"
            android:background="@drawable/input_bg" android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Breed" android:textColor="@color/dark_green"
            android:textStyle="bold" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etBreed"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:hint="e.g. Golden Retriever"
            android:background="@drawable/input_bg" android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age (years) *" android:textColor="@color/dark_green"
                    android:textStyle="bold" android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etAge"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:hint="e.g. 3" android:inputType="number"
                    android:background="@drawable/input_bg" android:padding="14dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight (kg)" android:textColor="@color/dark_green"
                    android:textStyle="bold" android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etWeight"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:hint="e.g. 12.5" android:inputType="numberDecimal"
                    android:background="@drawable/input_bg" android:padding="14dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health Notes" android:textColor="@color/dark_green"
            android:textStyle="bold" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etHealthNotes"
            android:layout_width="match_parent" android:layout_height="100dp"
            android:hint="Any allergies, medications, conditions..."
            android:background="@drawable/input_bg" android:padding="14dp"
            android:gravity="top" android:layout_marginBottom="24dp"/>

        <!-- Pet Photo Upload -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Photo 📷" android:textColor="@color/dark_green"
            android:textStyle="bold" android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView android:id="@+id/ivPetPhoto"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:scaleType="centerCrop"
                android:background="@drawable/input_bg"
                android:src="@android:drawable/ic_menu_camera"
                android:padding="16dp"
                android:layout_marginEnd="12dp"/>

            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button android:id="@+id/btnUploadPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Choose from Gallery"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_green"/>

                <TextView android:id="@+id/tvPhotoStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No photo selected"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Vaccination / Ownership Proof -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vaccination &amp; Ownership Proof 📄"
            android:textColor="@color/dark_green"
            android:textStyle="bold" android:textSize="13sp"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="8dp"/>

        <TextView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload vaccination certificate or registration document (PDF or image)"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnUploadProof"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📎  Upload Document"
            android:textSize="13sp"
            android:textColor="@color/dark_green"
            android:backgroundTint="@color/light_green"
            android:layout_marginBottom="6dp"/>

        <TextView android:id="@+id/tvProofStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No document selected"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="28dp"/>

        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Save &amp; Start Exploring 🐾"
            android:textSize="16sp" android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_green"/>
    </LinearLayout>
</ScrollView>