<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/surface"
    android:layout_marginBottom="4dp">

    <TextView android:id="@+id/tvSmallName"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:textStyle="bold"
        android:textColor="@color/text_dark"/>

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView android:id="@+id/tvSmallScore"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp" android:textColor="@color/accent_amber"/>

        <TextView android:id="@+id/tvSmallHours"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp" android:textColor="@color/text_muted"/>
    </LinearLayout>
</LinearLayout>
